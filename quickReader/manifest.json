{
    "manifest_version": 3,
    "name": "Quick Read",
    "version": "1.0",
    "description": "Otwórz zaznaczony tekst w trybie szybkiego czytania.",
    "permissions": [
        "contextMenus",
        "tabs"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Quick Read"
    },
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    }
}
