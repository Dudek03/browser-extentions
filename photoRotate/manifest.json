{
    "manifest_version": 3,
    "name": "photoRotate",
    "permissions": [
        "scripting",
        "contextMenus"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "description": "Enable focus mode on Chrome's official Extensions and Chrome Web Store documentation.",
    "version": "1.0",
    "background": {
        "service_worker": "rotator.js"
    }
}